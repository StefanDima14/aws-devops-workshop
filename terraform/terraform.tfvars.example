# Copy this to terraform.tfvars and fill in your values.
# cp terraform.tfvars.example terraform.tfvars

aws_region    = "eu-west-1"
project_name  = "devops-workshop"
environment   = "dev"
owner         = "stefan"
instance_type = "t3.micro"

# REQUIRED: your public IP for SSH. Get it with: curl -s https://checkip.amazonaws.com
my_ip_cidr = "203.0.113.5/32"

# Optional: name of an existing EC2 key pair for SSH. Leave "" to use SSM only.
key_pair_name = ""

# REQUIRED: your GitHub repo in "owner/name" form (used for OIDC trust).
github_repo = "your-user/aws-devops-workshop"

# --- Video (stored in a private S3 bucket, served via presigned URL) ---------
# Object key the app reads from the bucket.
video_object_key = "video.mp4"

# Optional: upload a local video on `terraform apply`. Leave "" to upload later
# with: aws s3 cp video.mp4 s3://<bucket>/<key>
video_source_path = ""

# Presigned URL lifetime (seconds).
presigned_url_expiry = 3600

# Fallback public URL used only until an object exists in the bucket.
video_url = "https://interactive-examples.mdn.mozilla.net/media/cc0-videos/flower.mp4"
