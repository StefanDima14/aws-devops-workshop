# Copy this to terraform.tfvars and fill in your values.
# cp terraform.tfvars.example terraform.tfvars

aws_region    = "eu-west-1"
project_name  = "devops-workshop"
environment   = "dev"
owner         = "stefan"
instance_type = "t3.micro"

# REQUIRED: your public IP for SSH. Get it with: curl -s https://checkip.amazonaws.com
my_ip_cidr = "203.0.113.5/32"

# Optional: name of an existing EC2 key pair for SSH. Leave "" to use SSM only.
key_pair_name = ""

# NOTE: github_repo is NOT set here — the OIDC trust lives in the bootstrap
# stack. See terraform/bootstrap/terraform.tfvars.example.

# --- Video (stored in a private S3 bucket, served via presigned URL) ---------
# Object key the app reads from the bucket.
video_object_key = "video.mp4"

# The video is uploaded on every `terraform apply` — including from the pipeline,
# which is why assets/video.mp4 is committed to git. Leave this commented out to
# take the default (../assets/video.mp4); set it to "" to skip the upload and put
# the object there yourself with: aws s3 cp video.mp4 s3://<bucket>/<key>
# video_source_path = "../assets/video.mp4"

# Presigned URL lifetime (seconds).
presigned_url_expiry = 3600

# Fallback public URL used only until an object exists in the bucket.
video_url = "https://interactive-examples.mdn.mozilla.net/media/cc0-videos/flower.mp4"
