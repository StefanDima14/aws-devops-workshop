# Terraform (commit .terraform.lock.hcl — it pins provider versions)
# Globs, not terraform/-prefixed paths, so they also cover terraform/bootstrap/.
**/.terraform/
*.tfstate
*.tfstate.*
**/tfplan
plan.txt
# Local config (never commit secrets / real values)
**/terraform.tfvars
**/backend.hcl
*.pem

# The demo video IS committed (it's a few MB) so that `terraform apply` can upload
# it to S3 from the pipeline, where no one has your laptop's files. A multi-GB asset
# would not belong in git — you'd upload it to S3 out of band instead.

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/

# OS / editor
.DS_Store

