# Terraform (commit .terraform.lock.hcl — it pins provider versions)
# Globs, not terraform/-prefixed paths, so they also cover terraform/bootstrap/.
**/.terraform/
*.tfstate
*.tfstate.*
**/tfplan
plan.txt
# Local config (never commit secrets / real values)
**/terraform.tfvars
**/backend.hcl
*.pem

# Video assets (large binaries live in S3, not git)
assets/*.mp4

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/

# OS / editor
.DS_Store

